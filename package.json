{
  "name": "@barrieretest/playwright",
  "version": "0.1.0",
  "description": "Playwright matchers for @barrieretest/core accessibility audits",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0",
    "@barrieretest/core": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@barrieretest/core": "latest",
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "playwright",
    "testing",
    "barrieretest"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://barrieretest.at",
  "bugs": {
    "url": "https://github.com/barrieretest/barrieretest-playwright/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/barrieretest/barrieretest-playwright"
  }
}
